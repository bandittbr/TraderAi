# TradeAI - Configuração de Ambiente
# Copie para .env e ajuste os valores conforme necessário

# ── Aplicação ──────────────────────────────────────────────────────────────
APP_NAME=TradeAI
APP_VERSION=12.5.0
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Banco de Dados ─────────────────────────────────────────────────────────
# SQLite local
DATABASE_URL=sqlite+aiosqlite:///./data/tradeai.db
# PostgreSQL (Railway) — descomentar em produção:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/tradeai

# ── CORS ───────────────────────────────────────────────────────────────────
# Origens permitidas (separadas por vírgula)
CORS_ORIGINS=http://localhost:3000,https://trader-ai-livid.vercel.app

# ── Logs ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/tradeai.log

# ── Segurança ──────────────────────────────────────────────────────────────
# Troque por uma chave aleatória em produção (ex: openssl rand -hex 32)
SECRET_KEY=change-this-secret-key-in-production

# ── Paper Trading ─────────────────────────────────────────────────────────
PAPER_INITIAL_BALANCE=200
PAPER_RISK_PER_TRADE=10
PAPER_STOP_LOSS_PERCENT=2
PAPER_TAKE_PROFIT_PERCENT=4

# ── Trade Management ───────────────────────────────────────────────────────
PAPER_MAX_HOURS_OPEN=48
PAPER_BREAK_EVEN_TRIGGER_PCT=1.5
PAPER_TRAILING_START_PCT=2.0
PAPER_TRAILING_DISTANCE_PCT=1.0
PAPER_TP1_PCT=2.0
PAPER_EXIT_SCORE_THRESHOLD=30.0
