# TradeAI Frontend - Variáveis de Ambiente
# Copie para .env.local e ajuste conforme necessário

# URL do backend (usada em chamadas server-side)
BACKEND_URL=http://127.0.0.1:8000

# Variáveis expostas ao cliente (prefixo NEXT_PUBLIC_ obrigatório)
NEXT_PUBLIC_APP_NAME=TradeAI
NEXT_PUBLIC_APP_VERSION=2.0.0
NEXT_PUBLIC_API_BASE=/api/v1

# WebSocket — conexão direta ao backend (não passa pelo proxy Next.js)
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8000/api/v1/ws/market
