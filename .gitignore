# TradeAI — Git Ignore

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.venv/
venv/
env/
*.egg-info/
dist/
build/

# ── Ambiente e segredos ───────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Banco de dados (gerado em runtime) ───────────────────────────────────────
backend/data/*.db
backend/data/*.db-shm
backend/data/*.db-wal

# ── Logs ─────────────────────────────────────────────────────────────────────
backend/logs/

# ── Next.js ──────────────────────────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/node_modules/
frontend/.turbo/

# ── Sistema ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
