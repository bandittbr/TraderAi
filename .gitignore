# TradeAI — Git Ignore

# ── Dados sensíveis locais ────────────────────────────────────────────────────
DADOS.md

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.venv/
venv/
env/
*.egg-info/
dist/
build/

# ── Ambiente e segredos ───────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── OpenWork/OpenCode config (contém API keys) ────────────────────────────────
.config/

# ── Banco de dados (gerado em runtime) ───────────────────────────────────────
backend/data/*.db
backend/data/*.db-shm
backend/data/*.db-wal

# ── Logs ─────────────────────────────────────────────────────────────────────
backend/logs/
/logs/

# ── Imagens/artefatos gerados em runtime (Biel) ───────────────────────────────
backend/data/biel_images/
/data/

# ── Next.js ──────────────────────────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/node_modules/
frontend/.turbo/
frontend/next-env.d.ts
frontend/tsconfig.tsbuildinfo

# ── Sistema ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.cannot_delete_sandbox_limitation/
